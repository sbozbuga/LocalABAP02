     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZSBTMP_GEN_TREE</TDNAME>
      <TDID>RE</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00001</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;PURPOSE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der generische Tabellen-Änderungsprotokoll-Explorer dient zur</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>interaktiven Untersuchung, Dekodierung und Analyse von</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Tabellenänderungen (aus Tabelle DBTABLOG) für jede protokollierte</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Tabelle im SAP-System.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;INTEGRATION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Das Programm nutzt RTTI (Run-Time Type Information), um die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Tabellenstruktur zur Laufzeit dynamisch zu analysieren und die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Protokolldaten aus den Rohdaten-Bytes zu rekonstruieren, ohne dass</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>die Tabelle im Programm statisch definiert sein muss.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FEATURES&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;SELECTION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Auswertung kann über den Tabellennamen (P_TAB) und das</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Protokolldatum (s_logdat) eingeschränkt werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Zusätzliche Filter ermöglichen eine Einschränkung nach dem</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Protokollschlüssel (s_key), ändernden Benutzer (USERA),</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Transaktionscode (tcode) und Operationstyp (optype; Standard 'U').</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Option 'Nur echte Änderungen' (P_REAL) filtert Einträge heraus,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>bei denen sich die Werte nicht geändert haben.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;OUTPUT&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Online-Modus wird ein geteilter Bildschirm angezeigt:</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Linker Bereich: Ein ALV-Baum zur Gruppierung nach Datensatzschlüssel.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Rechter Bereich: Ein ALV-Grid mit der detaillierten Historie der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>  Feldänderungen (mit Farbhervorhebung und Symbolen).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Hintergrundmodus (Batch) wird eine flache Liste ausgegeben.</TDLINE>
      </TLINE>
     </LINES>
    </item>
