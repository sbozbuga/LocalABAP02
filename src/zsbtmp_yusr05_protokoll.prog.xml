      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Ermitteln der Änderungen an Benutzerparametern.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es werden lediglich Änderungen an noch existierenden Benutzern</TDLINE>
