     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZSBTMP_USR05_TREE</TDNAME>
      <TDID>RE</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00001</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;PURPOSE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der USR05 Änderungsbeleg-Explorer dient zur Anzeige und Analyse der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Änderungshistorie von Benutzerparametern (Tabelle USR05).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Das Programm dekodiert die in Tabelle DBTABLOG aufgezeichneten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Änderungen und zeigt den Verlauf von Einfügungen, Aktualisierungen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>und Löschungen pro Benutzer an.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;INTEGRATION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Tabellenprotokollierung für die Tabelle USR05 muss im System</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>aktiviert sein (Profilparameter rec/client), damit Änderungen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>protokolliert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FEATURES&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;SELECTION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Protokolle können nach Benutzer (BNAME) und Log-Datum</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(LOGDATE) gefiltert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Weitere Filter ermöglichen die Einschränkung nach dem ändernden</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Benutzer (USERA), Transaktionscode (TCODE) und Operationstyp</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(OPTYPE; Standardwert &apos;U&apos;).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Option &apos;Nur echte Änderungen&apos; (P_REAL) filtert Einträge heraus,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>bei denen sich der Parameterwert nicht geändert hat.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;OUTPUT&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Online-Modus wird ein geteilter Bildschirm angezeigt:</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Linker Bereich: Ein hierarchischer Baum der Benutzer und ihrer</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>  Parameter-IDs.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Rechter Bereich: Ein ALV-Grid mit der Historie der Änderungen für</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>  den ausgewählten Knoten (mit Farbhervorhebung und Symbolen).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Hintergrundmodus (Batch) wird eine flache Liste ausgegeben.</TDLINE>
      </TLINE>
     </LINES>
    </item>
