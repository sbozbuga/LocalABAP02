   <LONGTEXTS>
    <item>
     <DOKIL>
      <ID>RE</ID>
      <OBJECT>ZSBTMP_USR05_TREE</OBJECT>
      <LANGU>E</LANGU>
      <TYP>E</TYP>
      <VERSION>0001</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00020</TXTLINES>
      <DOKSTATE>R</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZSBTMP_USR05_TREE</TDNAME>
      <TDID>RE</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00001</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;PURPOSE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The USR05 Change Logs Explorer displays and analyzes change history</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>for user parameters (table USR05).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>It decodes raw changes recorded in table DBTABLOG and displays a</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>detailed history of parameter insertions, updates, and deletions.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;INTEGRATION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Table logging must be active for table USR05 in the system (system</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>profile parameter rec/client) for change logs to be recorded.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FEATURES&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;SELECTION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>You can filter the logs by User Name (BNAME) and Log Date (LOGDATE).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Additional filters allow restricting by the modifying user (USERA),</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Transaction Code (TCODE), and Operation Type (OPTYPE; default &apos;U&apos;).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The checkbox &apos;only actual changes&apos; (P_REAL) filters out entries</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>where the parameter value did not change (old value equals new value).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U2</TDFORMAT>
       <TDLINE>&amp;OUTPUT&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In online mode, a split-screen layout is displayed:</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Left Pane: A hierarchical tree of Users and their Parameter IDs.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>- Right Pane: A ALV Grid listing the history of changes for the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>  selected node. It displays change icons, old/new values with color</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>  highlighting, and metadata (date, time, user, and transaction).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In background (batch) mode, a flat list of change logs is printed.</TDLINE>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>RE</ID>
